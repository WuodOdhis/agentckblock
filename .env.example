# === CKB Agent Lock Configuration ===
# Copy this to .env and fill in your values

# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The secp256k1 private key the agent uses to sign transactions
# On devnet: use one of the keys from `offckb accounts`
# On mainnet: generate a fresh key, fund it, and NEVER share it
AGENT_PRIVATE_KEY=0x...

# The wallet used to fund agent-locked cells (must have CKB)
# On devnet: use a pre-funded account key from `offckb accounts`
PRIMARY_WALLET_PRIVATE_KEY=0x...

# Port for the Express server (default: 3000)
PORT=3000
